{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/public/build/$1" },
    { "src": "/(.*)\\.(php|css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2)$", "dest": "/public/$1.$2" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
